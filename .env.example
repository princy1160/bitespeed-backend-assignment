# Database Configuration
# For local development (use individual variables)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=identity_db
DB_USER=postgres
DB_PASSWORD=your_password

# For production/Render (use DATABASE_URL instead)
DATABASE_URL=postgresql://postgres:your_password@host:5432/identity_db

# Server Configuration
PORT=3000
NODE_ENV=development
